@model WebApiRZHD.Models.Schedule

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Schedule</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Departure_station" class="control-label"></label>
                <select asp-for="Departure_station" class="form-control" asp-items="ViewBag.Departure_station"></select>
                <span asp-validation-for="Departure_station" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Arrival_station" class="control-label"></label>
                <select asp-for="Arrival_station" class="form-control" asp-items="ViewBag.Arrival_station"></select>
                <span asp-validation-for="Arrival_station" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Departure_date_time" class="control-label"></label>
                <input asp-for="Departure_date_time" class="form-control" />
                <span asp-validation-for="Departure_date_time" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Arrival_date_time" class="control-label"></label>
                <input asp-for="Arrival_date_time" class="form-control" />
                <span asp-validation-for="Arrival_date_time" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Number_of_available_seats" class="control-label"></label>
                <input asp-for="Number_of_available_seats" class="form-control" />
                <span asp-validation-for="Number_of_available_seats" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ticket_price" class="control-label"></label>
                <input asp-for="Ticket_price" class="form-control" />
                <span asp-validation-for="Ticket_price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
